<Window x:Class="QrCodeGenerator.InstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:props="clr-namespace:QrCodeGenerator.Properties"
        Title="{x:Static props:Resources.InstallDialogTitle}"
        Height="360"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        Background="{StaticResource ContentBgBrush}">
    <Border Margin="24" Padding="24" Background="{StaticResource CardBgBrush}" CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.1" Color="{StaticResource ShadowColor}"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="DialogTitleText"
                       Text="{x:Static props:Resources.InstallDialogTitle}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextDarkBrush}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="DialogDescriptionText"
                       Grid.Row="1"
                       Text="{x:Static props:Resources.InstallDialogDescription}"
                       FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <StackPanel Grid.Row="2">
                <RadioButton x:Name="LocalOption"
                             GroupName="InstallScope"
                             IsChecked="True"
                             Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock x:Name="LocalOptionTitleText"
                                   Text="{x:Static props:Resources.InstallOptionLocalTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock x:Name="LocalOptionDescriptionText"
                                   Text="{x:Static props:Resources.InstallOptionLocalDescription}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="AllUsersOption"
                             GroupName="InstallScope">
                    <StackPanel>
                        <TextBlock x:Name="AllUsersOptionTitleText"
                                   Text="{x:Static props:Resources.InstallOptionAllUsersTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock x:Name="AllUsersOptionDescriptionText"
                                   Text="{x:Static props:Resources.InstallOptionAllUsersDescription}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="CancelButton"
                        Content="{x:Static props:Resources.InstallDialogCancel}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton"
                        Content="{x:Static props:Resources.InstallDialogConfirm}"
                        Style="{StaticResource PrimaryButton}"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>