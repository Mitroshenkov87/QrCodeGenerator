<Window x:Class="QrCodeGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:props="clr-namespace:QrCodeGenerator.Properties"
        mc:Ignorable="d"
        Title="{x:Static props:Resources.WindowTitle}"
        Icon="/Assets/app-icon.ico"
        Height="680"
        Width="960"
        MinHeight="560"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource ContentBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E293B" Offset="0"/>
                    <GradientStop Color="#172033" Offset="0.55"/>
                    <GradientStop Color="#1A2744" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="28,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,28">
                    <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,0,16"
                            HorizontalAlignment="Left"
                            Background="#1E293B">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                              Opacity="0.35" Color="{StaticResource PrimaryColor}"/>
                        </Border.Effect>
                        <Image Source="Assets/sidebar-badge.png"
                               Width="48" Height="48"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="AppTitleText"
                               Text="{x:Static props:Resources.AppTitle}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextLightBrush}"/>
                    <TextBlock x:Name="AppSubtitleText"
                               Text="{x:Static props:Resources.AppSubtitle}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <TextBlock x:Name="InputLabelText" Grid.Row="1"
                           Text="{x:Static props:Resources.InputLabel}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextLightBrush}"
                           Margin="0,0,0,10"/>

                <Border Grid.Row="2"
                        Background="{StaticResource SidebarLightBrush}"
                        CornerRadius="12"
                        Padding="2"
                        Margin="0,0,0,16">
                    <TextBox x:Name="InputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{StaticResource TextLightBrush}"
                             BorderThickness="0"
                             Padding="14,12"
                             FontSize="14"
                             MinHeight="180"
                             MaxLength="4000"
                             AutomationProperties.Name="{x:Static props:Resources.AutomationInputTextBox}"
                             TextChanged="InputTextBox_TextChanged"/>
                </Border>

                <StackPanel Grid.Row="3">
                    <StackPanel x:Name="InstallPanel">
                        <TextBlock x:Name="InstallLabelText"
                                   Text="{x:Static props:Resources.InstallLabel}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextLightBrush}"
                                   Margin="0,0,0,6"/>
                        <Button x:Name="InstallButton"
                                Style="{StaticResource SidebarActionButton}"
                                Margin="0,0,0,16"
                                Click="InstallButton_Click"
                                AutomationProperties.Name="{x:Static props:Resources.AutomationInstallButton}"/>
                    </StackPanel>

                    <TextBlock x:Name="LanguageLabelText"
                               Text="{x:Static props:Resources.LanguageLabel}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextLightBrush}"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="LanguageComboBox"
                              Style="{StaticResource SidebarComboBox}"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="{x:Static props:Resources.AutomationLanguageSelector}"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LabelWithFlag}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ComboTextBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock x:Name="CharacterCountText"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="StatusHintText"
                               Text="{x:Static props:Resources.InputPlaceholder}"
                               FontSize="12"
                               Foreground="{StaticResource HintTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right content -->
        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBgBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Margin="0,0,0,24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                      Opacity="0.08" Color="{StaticResource ShadowColor}"/>
                </Border.Effect>
                <Grid>
                    <Border x:Name="PlaceholderPanel"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Border Width="80" Height="80" CornerRadius="18"
                                    Background="{StaticResource PlaceholderIconBgBrush}" Margin="0,0,0,16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                                      Opacity="0.12" Color="{StaticResource AccentColor}"/>
                                </Border.Effect>
                                <Image Source="Assets/app-icon-96.png"
                                       Width="56" Height="56"
                                       Opacity="0.85"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="PlaceholderTitleText"
                                       Text="{x:Static props:Resources.PlaceholderTitle}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextDarkBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PlaceholderSubtitleText"
                                       Text="{x:Static props:Resources.PlaceholderSubtitle}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="QrPreviewBorder"
                            Background="{StaticResource CardBgBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                              Opacity="0.06" Color="{StaticResource ShadowColor}"/>
                        </Border.Effect>
                        <Grid>
                            <Image x:Name="QrPreviewImage"
                                   Stretch="Uniform"
                                   MaxWidth="380"
                                   MaxHeight="380"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   AutomationProperties.Name="{x:Static props:Resources.AutomationQrPreview}"/>

                            <Border x:Name="LoadingOverlay"
                                    Background="#80FFFFFF"
                                    CornerRadius="12"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="LoadingTextBlock"
                                           Text="{x:Static props:Resources.LoadingText}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDarkBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="GenerateButton"
                        Content="{x:Static props:Resources.GenerateButton}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,12,0"
                        Click="GenerateButton_Click"
                        IsEnabled="False"
                        AutomationProperties.Name="{x:Static props:Resources.AutomationGenerateButton}"/>
                <Button x:Name="SaveButton"
                        Content="{x:Static props:Resources.SaveButton}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"
                        Click="SaveButton_Click"
                        IsEnabled="False"
                        AutomationProperties.Name="{x:Static props:Resources.AutomationSaveButton}"/>
                <Button x:Name="ClearButton"
                        Content="{x:Static props:Resources.ClearButton}"
                        Style="{StaticResource DangerButton}"
                        Click="ClearButton_Click"
                        IsEnabled="False"
                        AutomationProperties.Name="{x:Static props:Resources.AutomationClearButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>